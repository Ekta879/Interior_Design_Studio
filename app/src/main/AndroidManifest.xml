<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.interiordeisgnstudio1">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InteriorDeisgnStudio1">

        <!-- ONLY ONE LAUNCHER -->
        <activity
            android:name=".view.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.InteriorDeisgnStudio1">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- OTHER ACTIVITIES -->
        <activity
            android:name=".view.RegistrationActivity"
            android:exported="true" />

        <activity
            android:name=".view.LoginActivity"
            android:exported="true" />

        <activity
            android:name=".view.ForgotPasswordActivity"
            android:exported="true" />

        <activity
            android:name=".view.ClientDashboardActivity"
            android:exported="true" />

        <activity
            android:name=".view.MainActivity"
            android:exported="false" />

    </application>

</manifest>